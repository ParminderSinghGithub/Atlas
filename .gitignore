# -------------------------
# Runtime ML Artifacts
# -------------------------

# Ignore everything by default
notebooks/artifacts/**

# Keep required runtime model artifacts
!notebooks/artifacts/models/
!notebooks/artifacts/models/production_v1/
!notebooks/artifacts/models/production_v1/lightgbm_ranker.txt
!notebooks/artifacts/models/production_v1/svd_model.pkl
!notebooks/artifacts/models/production_v1/item_similarity.pkl
!notebooks/artifacts/models/production_v1/popularity_baseline.pkl

# Keep required runtime feature tables
!notebooks/artifacts/features/
!notebooks/artifacts/features/retailrocket/
!notebooks/artifacts/features/retailrocket/user_features.parquet
!notebooks/artifacts/features/retailrocket/item_features.parquet

