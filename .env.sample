# ===========================================
# RUNTIME VERSIONS (Base Images)
# ===========================================
PYTHON_VERSION=3.13-slim
NODE_VERSION=20-alpine
GO_VERSION=1.25.4-alpine
REDIS_VERSION=8
POSTGRES_VERSION=17

# ===========================================
# FRAMEWORK & LIBRARY VERSIONS
# ===========================================
# Frontend
REACT_VERSION=19.2.0
VITE_VERSION=7.2.2
TYPESCRIPT_VERSION=5.9.3
TAILWIND_VERSION=4.1.17

# Backend - Python (API Gateway)
FASTAPI_VERSION=latest
UVICORN_VERSION=latest
HTTPX_VERSION=latest

# Backend - Node.js (User Service)
EXPRESS_VERSION=5.1.0
CORS_VERSION=2.8.5
DOTENV_VERSION=17.2.3

# Backend - Go (Product Service)
GIN_VERSION=1.11.0

# ===========================================
# SERVICE PORTS
# ===========================================
FRONTEND_PORT=5174
API_GATEWAY_PORT=8000
USER_SERVICE_PORT=5000
PRODUCT_SERVICE_PORT=5001
POSTGRES_PORT=5432
REDIS_PORT=6379

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce
